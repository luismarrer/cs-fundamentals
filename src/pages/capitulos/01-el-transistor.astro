        <rect x="60" y="120" width="440" height="110" rx="8" fill="#f4c9c9" opacity="0.55"></rect>
        <text x="280" y="215" text-anchor="middle" font-size="14" fill="#a15555">sustrato tipo P</text>
        <rect x="80" y="120" width="90" height="55" rx="6" fill="#b9d7f5"></rect>
        <text x="125" y="152" text-anchor="middle" font-size="13" fill="#3a6ea8">N</text>
        <rect x="390" y="120" width="90" height="55" rx="6" fill="#b9d7f5"></rect>
        <text x="435" y="152" text-anchor="middle" font-size="13" fill="#3a6ea8">N</text>
        <rect x="180" y="108" width="200" height="12" fill="#d9d9d9"></rect>
        <rect x="200" y="80" width="160" height="26" rx="5" id="gate-plate" fill="#9aa5b5"></rect>
        <text x="280" y="98" text-anchor="middle" font-size="13" fill="#fff" font-weight="700">GATE</text>
        <rect x="170" y="120" width="220" height="16" rx="6" id="channel" fill="#4f8fe0" opacity="0"></rect>
        <text x="125" y="110" text-anchor="middle" font-size="13" fill="currentColor">Fuente</text>
        <text x="435" y="110" text-anchor="middle" font-size="13" fill="currentColor">Drenador</text>
        <g id="electrons" opacity="0">
          <circle r="5" fill="#2563eb"><animate attributeName="cx" from="130" to="430" dur="1.2s" repeatCount="indefinite"></animate><animate attributeName="cy" from="128" to="128" dur="1.2s" repeatCount="indefinite"></animate></circle>
          <circle r="5" fill="#2563eb"><animate attributeName="cx" from="130" to="430" dur="1.2s" begin="0.4s" repeatCount="indefinite"></animate><animate attributeName="cy" from="128" to="128" dur="1.2s" begin="0.4s" repeatCount="indefinite"></animate></circle>
          <circle r="5" fill="#2563eb"><animate attributeName="cx" from="130" to="430" dur="1.2s" begin="0.8s" repeatCount="indefinite"></animate><animate attributeName="cy" from="128" to="128" dur="1.2s" begin="0.8s" repeatCount="indefinite"></animate></circle>

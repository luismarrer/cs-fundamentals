---
interface Props {
  href: string;
  num: string;
  title: string;
  external?: boolean;
  ext?: string;
}

const { href, num, title, external = false, ext } = Astro.props;
const externalAttrs = external ? { target: '_blank', rel: 'noopener' } : {};
---

<a
  class="block rounded-2xl border border-line bg-elev px-6 py-5 transition-all hover:-translate-y-0.5 hover:border-accent"
  href={href}
  {...externalAttrs}
>
  <span
    class="mb-3 inline-flex h-8 w-8 items-center justify-center rounded-lg bg-accent-soft font-mono text-sm font-bold text-accent"
  >
    {num}
  </span>
  <h3 class="mb-1 text-lg font-semibold tracking-tight">{title}</h3>
  <p class="text-sm text-soft"><slot /></p>
  {ext && <span class="mt-3 inline-block text-sm font-semibold text-accent">{ext} ↗</span>}
</a>
